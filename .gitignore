__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.antigravitycli/
# agy drops a workspace-local cache/ (projects.json with your home path) when
# run with cwd set to a project dir — keep it out of the repo.
/cache/
.idea/
.vscode/
*.log

# Test/lint tool caches
.pytest_cache/
.ruff_cache/

# Stray uv lockfile — this project builds with pip/setuptools, not uv.
uv.lock

# Local-only superpowers planning/spec docs — keep these out of the public repo.
docs/superpowers/

# Local git-bundle backups (e.g. agy-repo-backup-pre-scrub.bundle) — never publish.
*.bundle
